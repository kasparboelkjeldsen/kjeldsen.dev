{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 nuxi dev",
    "dev-nocache": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 USE_CACHE=false nuxi dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
