    "@tailwindcss/typography": "^0.5.16",
    "chart.js": "^4.4.9",
    "nuxt": "^3.16.0",
    "redis": "^4.7.0",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@types/markdown-it": "^14.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.24.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "nuxt-multi-cache": "^3.4.0",
